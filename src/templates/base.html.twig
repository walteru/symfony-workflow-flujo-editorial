<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Flujo editorial · Symfony Workflow{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📝</text></svg>">
        <style>
            :root { --bg:#0f172a; --card:#1e293b; --line:#334155; --txt:#e2e8f0; --muted:#94a3b8; --accent:#38bdf8; }
            * { box-sizing: border-box; }
            body { margin:0; font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background:var(--bg); color:var(--txt); line-height:1.5; }
            a { color:var(--accent); }
            header { display:flex; justify-content:space-between; align-items:center; gap:1rem; padding:1rem 1.5rem; border-bottom:1px solid var(--line); flex-wrap:wrap; }
            header h1 { font-size:1.1rem; margin:0; }
            header h1 a { color:var(--txt); text-decoration:none; }
            main { max-width: 820px; margin: 0 auto; padding: 1.5rem; }
            .rol { font-size:.85rem; color:var(--muted); }
            .rol strong { color:var(--txt); }
            .card { background:var(--card); border:1px solid var(--line); border-radius:12px; padding:1.25rem; margin-bottom:1rem; }
            .btn { display:inline-block; border:0; border-radius:8px; padding:.5rem .9rem; font-size:.9rem; cursor:pointer; text-decoration:none; background:#334155; color:var(--txt); }
            .btn:hover { filter:brightness(1.15); }
            .btn-primary { background:var(--accent); color:#04293a; font-weight:600; }
            .badge { display:inline-block; padding:.2rem .6rem; border-radius:999px; font-size:.75rem; font-weight:600; text-transform:uppercase; letter-spacing:.03em; }
            .badge.borrador { background:#475569; color:#e2e8f0; }
            .badge.en_revision { background:#facc15; color:#422006; }
            .badge.aprobado { background:#34d399; color:#022c22; }
            .badge.rechazado { background:#f87171; color:#450a0a; }
            .badge.publicado { background:#38bdf8; color:#04293a; }
            .flash { padding:.7rem 1rem; border-radius:8px; margin-bottom:1rem; font-size:.9rem; }
            .flash.exito { background:#064e3b; color:#a7f3d0; }
            .flash.error { background:#7f1d1d; color:#fecaca; }
            label { display:block; font-size:.85rem; color:var(--muted); margin:.8rem 0 .25rem; }
            input, textarea { width:100%; padding:.6rem; border-radius:8px; border:1px solid var(--line); background:#0b1220; color:var(--txt); font:inherit; }
            .acciones { display:flex; gap:.5rem; flex-wrap:wrap; margin-top:1rem; }
            .muted { color:var(--muted); font-size:.85rem; }
            ul.lista { list-style:none; padding:0; margin:0; }
            ul.lista li { display:flex; justify-content:space-between; align-items:center; gap:1rem; padding:.7rem 0; border-bottom:1px solid var(--line); }
        </style>
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <header>
            <h1><a href="{{ path('articulos_listar') }}">📝 Flujo editorial</a></h1>
            <div class="rol">
                Rol actual: <strong>{{ rol|default('autor') }}</strong>
                {% if rol|default('autor') == 'editor' %}
                    · <a href="{{ path('cambiar_rol', {rol:'autor'}) }}">ver como autor</a>
                {% else %}
                    · <a href="{{ path('cambiar_rol', {rol:'editor'}) }}">ver como editor</a>
                {% endif %}
            </div>
        </header>
        <main>
            {% for tipo in ['exito', 'error'] %}
                {% for mensaje in app.flashes(tipo) %}
                    <div class="flash {{ tipo }}">{{ mensaje }}</div>
                {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
